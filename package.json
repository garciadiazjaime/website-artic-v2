{
  "name": "my-e2e-library",
  "engines": {
    "node": "^20.3.0"
  },
  "engines-annotation": "Mostly required by sharp which needs a Node-API v9 compatible runtime",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "qwik build",
    "build.client": "vite build",
    "build.server": "vite build -c adapters/netlify-edge/vite.config.ts",
    "build.preview": "vite build --ssr src/entry.preview.tsx",
    "build.types": "tsc --incremental --noEmit",
    "deploy": "netlify deploy --build",
    "dev": "vite --mode ssr",
    "dev.debug": "node --inspect-brk ./node_modules/vite/bin/vite.js --mode ssr --force",
    "fmt": "prettier --write .",
    "fmt.check": "prettier --check .",
    "lint": "eslint \"src/**/*.ts*\"",
    "preview": "qwik build preview && vite preview --open",
    "start": "vite --open --mode ssr",
    "qwik": "qwik",
    "postbuild": "cp .netlify/edge-functions/entry.netlify-edge/@qwik-city-not-found-paths.js .netlify/edge-functions/entry.netlify-edge/qwik-city-not-found-paths.js && cp .netlify/edge-functions/entry.netlify-edge/@qwik-city-not-found-paths.js netlify/edge-functions/entry.netlify-edge/qwik-city-not-found-paths.js"
  },
  "devDependencies": {
    "@builder.io/qwik": "1.11.0",
    "@builder.io/qwik-city": "1.11.0",
    "@eslint/js": "^8.0.0",
    "@netlify/edge-functions": "^2.0.0",
    "@types/node": "20.19.0",
    "eslint": "8.57.0",
    "eslint-plugin-qwik": "1.11.0",
    "globals": "^13.0.0",
    "netlify-cli": "^15.0.0",
    "prettier": "3.6.2",
    "typescript": "5.4.5",
    "typescript-eslint": "^7.18.0",
    "typescript-plugin-css-modules": "latest",
    "undici": "*",
    "vite": "5.4.19",
    "vite-tsconfig-paths": "^4.2.1"
  }
}
